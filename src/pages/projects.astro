---
import { getCollection, render } from "astro:content";
import Layout from "../layouts/Layout.astro";

const projects = await getCollection("projects");

const projectEntries = await Promise.all(
  projects.map(async (p) => {
    const { Content } = await render(p);
    return { ...p.data, Content };
  })
);
---

<Layout title="Projects — Phillip Logan">
  <main>
    <section class="container">
      <div class="intro">
        <h1>Projects</h1>
        <p class="intro-sub">Stuff I made and stuff I helped to make.</p>
      </div>
      <div class="project-list">
        {projectEntries.map((project) => (
          <article class="project">
            <div class="project-top">
              <h2 class="project-title">{project.title}</h2>
              {project.link && (
                <a
                  class="project-link"
                  href={`https://${project.link}`}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {project.link} <span aria-hidden="true">↗</span>
                </a>
              )}
            </div>
            <div class="project-body">
              <project.Content />
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
</Layout>

<style>
  .intro {
    padding: 30px 0 24px;
  }
  .intro h1 {
    margin-bottom: 0.2em;
  }
  .intro-sub {
    color: var(--muted);
    font-size: 15px;
    margin-bottom: 0;
  }
  .project-list {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }
  .project {
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border);
  }
  .project:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .project-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 6px;
  }
  .project-title {
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
  }
  .project-link {
    font-size: 13px;
    color: var(--accent);
    white-space: nowrap;
  }
  .project-body {
    font-size: 14px;
    line-height: 1.55;
    color: var(--fg);
  }
  .project-body :global(p) {
    margin-bottom: 0.5em;
  }
  .project-body :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
