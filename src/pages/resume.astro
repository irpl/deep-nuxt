---
import { getCollection, getEntry, render } from "astro:content";
import { Icon } from "astro-icon/components";
import Layout from "../layouts/Layout.astro";
import ResumeBlock from "../components/ResumeBlock.astro";

const blurbEntry = await getEntry("pages", "blurb");
const skillsEntry = await getEntry("pages", "skills");
const eduEntry = await getEntry("pages", "education");
const hobbiesEntry = await getEntry("pages", "hobbies");

const { Content: BlurbContent } = blurbEntry ? await render(blurbEntry) : { Content: null };
const { Content: SkillsContent } = skillsEntry ? await render(skillsEntry) : { Content: null };
const { Content: HobbiesContent } = hobbiesEntry ? await render(hobbiesEntry) : { Content: null };

const experiences = await getCollection("experience");
experiences.sort((a, b) => {
  const aEnd = a.data.end ?? "9999-99";
  const bEnd = b.data.end ?? "9999-99";
  if (aEnd !== bEnd) return bEnd.localeCompare(aEnd);
  return b.data.start.localeCompare(a.data.start);
});

const experienceEntries = await Promise.all(
  experiences.map(async (e) => {
    const { Content } = await render(e);
    return { ...e.data, Content, id: e.id };
  })
);

const views = ["dev", "qa", "teacher", "full"] as const;
---

<Layout title="Resume — Phillip Logan">
  <main>
    <section>
      <div class="resume">
        <div class="resume-container">
          <div class="resume-banner">
            <div>
              <h1>Phillip Logan</h1>
            </div>

            <div class="resume-blurb-table">
              <div class="resume-blurb-table-item">
                <Icon name="fa6-solid:phone" /> +1 876-840-4247
              </div>
              <div class="resume-blurb-table-item">
                <Icon name="fa6-solid:envelope" /> phillipllogan@gmail.com
              </div>
              <div class="resume-blurb-table-item">
                <Icon name="fa6-solid:link" /> philliplogan.com
              </div>
            </div>
          </div>

          <div class="view-switcher no-print" role="tablist">
            {views.map((v) => (
              <button
                class="view-btn"
                data-view={v}
                type="button"
                aria-label={`Show ${v} view`}
              >
                {v === "qa" ? "QA" : v}
              </button>
            ))}
          </div>

          <h2><Icon name="fa6-solid:user" /> Profile</h2>
          {BlurbContent && (
            <div>
              <BlurbContent />
            </div>
          )}

          <h2><Icon name="fa6-solid:code" /> Skills</h2>
          {SkillsContent && (
            <div class="skills-section">
              <SkillsContent />
            </div>
          )}

          <h2><Icon name="fa6-solid:briefcase" /> Experience</h2>
          {experienceEntries.map((exp) => (
            <div class="exp-wrapper" data-types={exp.types.join(" ")}>
              <ResumeBlock
                position={exp.position}
                where={exp.where}
                duration={exp.duration}
              >
                <exp.Content />
              </ResumeBlock>
            </div>
          ))}

          <h2><Icon name="fa6-solid:school" /> Education</h2>
          {eduEntry && (
            <div class="education-line">
              {eduEntry.data.position}
              {eduEntry.data.where && <> &mdash; {eduEntry.data.where}</>}
              {eduEntry.data.duration && <> &mdash; {eduEntry.data.duration}</>}
            </div>
          )}

          <div data-show-on="full">
            <h2><Icon name="fa6-solid:puzzle-piece" /> Hobbies</h2>
            {HobbiesContent && (
              <div>
                <HobbiesContent />
              </div>
            )}
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  const STORAGE_KEY = "resume-view";
  const defaultView = "full";

  function applyView(view: string) {
    document.querySelectorAll<HTMLButtonElement>(".view-btn").forEach((btn) => {
      btn.classList.toggle("view-btn-active", btn.dataset.view === view);
    });
    document.querySelectorAll<HTMLElement>(".exp-wrapper").forEach((el) => {
      const types = (el.dataset.types || "").split(" ").filter(Boolean);
      const visible = view === "full" || types.includes(view);
      el.style.display = visible ? "" : "none";
    });
    document.querySelectorAll<HTMLElement>("[data-show-on]").forEach((el) => {
      const allowed = (el.dataset.showOn || "").split(" ").filter(Boolean);
      el.style.display = allowed.includes(view) ? "" : "none";
    });
  }

  const saved = localStorage.getItem(STORAGE_KEY) || defaultView;
  applyView(saved);

  document.querySelectorAll<HTMLButtonElement>(".view-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const view = btn.dataset.view || defaultView;
      localStorage.setItem(STORAGE_KEY, view);
      applyView(view);
    });
  });
</script>

<style>
  .resume {
    margin: 0 auto;
    max-width: 8.5in;
    padding: 30px 0;
    background-color: var(--card);
  }
  .resume-container {
    margin: 0 auto;
    width: 90%;
  }
  .resume-banner {
    display: flex;
    justify-content: space-between;
    margin-bottom: 20px;
  }
  .resume-banner :global(h1) {
    margin-bottom: 0;
  }
  .resume-blurb-table-item {
    margin-bottom: 10px;
  }
  .resume-container :global(h2) {
    font-weight: 600;
    font-size: 16px;
    text-transform: uppercase;
    letter-spacing: 1px;
    border-bottom: 1.5px solid var(--fg);
    padding-bottom: 4px;
    margin-top: 16px;
    margin-bottom: 10px;
  }
  .resume-container :global(h2 svg) {
    margin-right: 6px;
    font-size: 14px;
  }
  .resume-container :global(p) {
    margin-bottom: 0.5em;
    font-size: 14px;
    line-height: 1.5;
  }
  .skills-section {
    columns: 2;
    column-gap: 24px;
  }
  .skills-section :global(p) {
    margin-bottom: 0.2em;
    font-size: 13px;
    break-inside: avoid;
  }
  .education-line {
    font-size: 14px;
    line-height: 1.5;
    margin-bottom: 4px;
  }
  .view-switcher {
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
  }
  .view-btn {
    padding: 6px 16px;
    border: 1px solid var(--border);
    border-radius: 5px;
    background: var(--card);
    color: var(--fg);
    cursor: pointer;
    font-family: inherit;
    font-size: 14px;
    text-transform: capitalize;
  }
  .view-btn-active {
    background-color: var(--accent-soft);
    color: var(--accent);
    border-color: var(--accent);
  }

  @media print {
    .resume {
      background-color: white;
      color: black;
      padding: 0;
    }
    .resume-container {
      width: 100%;
    }
    .resume-banner {
      flex-direction: row;
      align-items: center;
    }
    .resume-blurb-table {
      display: flex;
      gap: 16px;
      font-size: 9pt;
    }
    .resume-blurb-table-item {
      width: unset;
    }
    .resume-container :global(h2) {
      margin-top: 12px;
      margin-bottom: 6px;
      border-bottom-color: black;
      break-after: avoid;
      page-break-after: avoid;
    }
    .exp-wrapper {
      break-inside: avoid;
      page-break-inside: avoid;
    }
  }
</style>
