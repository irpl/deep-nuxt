---
interface Props {
  position: string;
  where?: string | undefined;
  duration?: string | number | undefined;
}

const { position, where, duration } = Astro.props;
const hasSubtitle = !!(where || duration);
const subtitle = [where, duration].filter(Boolean).join(" | ");
---

<div class="resume-exp-table">
  <div class="resume-exp-table-body">
    <span class="resume-exp-table-position">{position}</span>
    {hasSubtitle && <div class="resume-exp-table-subtitle">{subtitle}</div>}
    <div class="resume-exp-table-content">
      <slot />
    </div>
  </div>
</div>

<style is:global>
  .resume-exp-table {
    margin-bottom: 16px;
  }
  .resume-exp-table-position {
    font-size: 16px;
    font-weight: 700;
    display: block;
  }
  .resume-exp-table-subtitle {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 4px;
  }
  .resume-exp-table-content ul {
    padding-left: 18px;
    margin-top: 2px;
  }
  .resume-exp-table-content li {
    margin-bottom: 2px;
    font-size: 14px;
    line-height: 1.5;
  }
</style>
